FoamFile
{
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
dimensions      [0 0 -1 0 0 0 0];
internalField   uniform 1.3564109246835638;
boundaryField
{
    inlet { type            turbulentMixingLengthFrequencyInlet;
            mixingLength    4.1;
            z0              uniform 0.8;
            flowDir         (1 0 0); 
            zDir            (0 0 1);
            zGround uniform 0.0;
            Zref 10.0;
            Uref            11.1;
            uStar           1.8018562723496463;
            kappa           0.41;
            value           $internalField; 
            }
    outlet { type zeroGradient; }
    ground { type omegaWallFunction; value $internalField; }
    buildings { type omegaWallFunction; value $internalField; }
    frontAndBack { type symmetry; }
    sky { type slip; }
}