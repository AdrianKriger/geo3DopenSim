FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
solver incompressibleFluid;
startFrom latestTime;
stopAt endTime;
endTime 1000;
deltaT 1;
writeInterval 100;
purgeWrite 2;
writeFormat ascii;
libs ("libatmosphericModels.so" "libfvModels.so");