FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
solver incompressibleFluid;
startFrom latestTime;
stopAt endTime;
endTime 1000;
deltaT 1;
writeInterval 100;
purgeWrite 2;
writeFormat ascii;
libs ("libatmosphericModels.so" "libfvModels.so");
functions
{
    hubSurface
    {
        type            surfaces;
        libs            ("libsampling.so");
        writeControl    writeTime;
        writeInterval   1000;    
        surfaceFormat   vtk;
    	interpolationScheme cell;
        
        // This ensures OpenFOAM tracks fields on the modified geometry
        fields          ( U k ); 

        surfaces
        {
            hubHeight100
            {
                type            distanceSurface;
            	surfaceType     triSurface;
            	file	        "terrain.obj";
                distance        100.0;    
             	signed          false;
		
                topology        proximityRegions; 
                absProximity    103;          
            }
            turbine60
            {
                type            distanceSurface;
            	surfaceType     triSurface;
            	file	        "terrain.obj";
                distance        60.0;    
             	signed          false;
		
                topology        proximityRegions; 
                absProximity    63.0;          
            }
            turbine150
            {
                type            distanceSurface;
            	surfaceType     triSurface;
            	file	        "terrain.obj";
                distance        150.0;    
             	signed          false;
		
                topology        proximityRegions; 
                absProximity    153.0;          
            }
        }
    }
}
